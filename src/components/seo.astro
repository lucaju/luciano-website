---
import { A, F, pipe, S } from '@mobily/ts-belt';
import { SEO, type SEOProps } from 'astro-seo';
import { match, P } from 'ts-pattern';

interface Props {
	title?: string;
	description: string;
	article?: Partial<NonNullable<SEOProps['openGraph']>['article']>;
	image?: Required<NonNullable<SEOProps['openGraph']>['image']>;
	keywords?: string[];
}

const defaultKeywords = ['luciano frizzera', 'luciano dos reis frizzera', 'lucaju'];

const { title: _title, description, article, ...props } = Astro.props;

const type = article ? 'article' : 'website';
const keywords = match(props.keywords)
	.with(P.array(), (kw) => pipe(kw, A.join(',')))
	.otherwise(() => A.join(defaultKeywords, ','));
const title = match(_title)
	.with(P.string, S.append(' | Luciano Frizzera, PhD'))
	.otherwise(() => 'Luciano Frizzera, PhD');

const image = match(props.image)
	.with(P.not(P.nullish), F.identity)
	.otherwise(
		() =>
			({
				height: 700,
				width: 1280,
				type: 'image/png',
				url: '/profile_pictures.png',
				secureUrl: '/profile_pictures.png',
				alt: 'Luciano Frizzera, PhD',
			}) satisfies Props['image'],
	);
---

<SEO
	{title}
	{description}
	openGraph={{
		article,
		image,
		optional: {
			description,
			locale: 'en',
			determiner: type,
			siteName: 'Luciano Frizzera, PhD',
		},
		basic: {
			title,
			type,
			image: image.url.toString(),
		},
	}}
	twitter={{
		title,
		description,
		image: image.url.toString(),
		card: 'summary_large_image',
		creator: '@lucaju',
		site: 'Luciano Frizzera, PhD',
		imageAlt: 'Luciano Frizzera, PhD',
	}}
	extend={{
		link: [
			{ rel: 'sitemap', href: '/sitemap-index.xml' },
			{ rel: 'icon', type: 'image/svg+xml', href: '/favicon.svg' },
		],
		meta: [
			{ name: 'keywords', content: keywords },
			{ name: 'author', content: 'Luciano Frizzera' },
			{ name: 'generator', content: Astro.generator },
			{ name: 'keywords', content: keywords },
			{ name: 'robots', content: 'index, follow' },
			{
				name: 'viewport',
				content: 'width=device-width, initial-scale=1, minimum-scale=1, viewport-fit=cover',
			},
			{
				name: 'googlebot',
				content: 'index, follow, max-video-preview:-1, max-image-preview:large, max-snippet:-1',
			},
		],
	}}
/>
