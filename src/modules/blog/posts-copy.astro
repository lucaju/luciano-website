---
import type { InferEntrySchema, RenderedContent } from 'astro:content';
import { dateToISO, formatDate } from '@/lib/date';

interface Props {
	posts: ReadonlyArray<{
		id: string;
		body?: string;
		collection: 'blogCollection';
		data: InferEntrySchema<'blogCollection'>;
		rendered?: RenderedContent;
		filePath?: string;
	}>;
}

const { posts } = Astro.props;
---

<section class="container-fluid py-10">
	<div class="border-l-2 border-muted">
		{
			posts.map((post) => (
				<div class="pl-10 not-last-of-type:pb-10 max-w-xl relative group">
					<p class="text-muted-foreground text-xs sm:text-sm font-light">
						<time datetime={dateToISO(post.data.publishedAt)}>{formatDate(post.data.publishedAt)}</time>
					</p>

					<h2 class="text-lg sm:text-xl text-balance lg:text-2xl font-semibold pb-4">{post.data.title}</h2>

					<div class="size-3 rounded-full absolute -left-1.75 top-px bg-linear-to-r from-orange-500 to-yellow-500 group-hover:scale-150 group-hover:rotate-180 transition duration-300" />

					<a title={post.data.title} href={`/blog/${post.id}`} class="absolute inset-0">
						<span class="sr-only">{post.data.title}</span>
					</a>
				</div>
			))
		}
	</div>
</section>
