---
import Hero from '@/components/hero.astro';
import Seo from '@/components/seo.astro';
import RootLayout from '@/layouts/root-layout.astro';

const title = '404 Not Found, Unable to Find the Requested Resource';
const description =
	'You might entered a wrong url, or the page you were looking for simply does not exist. If you think this is a mistake and want me to fix it, please send me an email with the attachment, I will gladly fix the issue.';
---

<RootLayout>
	<Seo slot="metadata" title={title} description={description} />

	<Hero {description}>
		<Fragment slot="title">
			{title}
		</Fragment>
	</Hero>
</RootLayout>
